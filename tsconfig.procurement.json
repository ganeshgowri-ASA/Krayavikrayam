{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "packages/procurement/src/**/*.ts",
    "packages/procurement/src/**/*.tsx",
    "packages/procurement/tests/**/*.ts",
    "packages/procurement/tests/**/*.tsx",
    "app/dashboard/procurement/**/*.tsx",
    "app/(procurement)/**/*.tsx",
    "vitest.config.ts",
    "vitest.setup.ts"
  ],
  "exclude": ["node_modules"]
}
