// ─── Agentic AI Models ────────────────────────────────────────────────────────

model AiAgentLog {
  id         String   @id @default(cuid())
  agentType  String
  input      String   @db.Text
  output     String   @db.Text
  status     String   @default("pending")
  durationMs Int?
  orgId      String
  createdAt  DateTime @default(now())

  @@index([orgId])
  @@index([agentType])
}

model ChatbotSession {
  id        String   @id @default(cuid())
  userId    String
  orgId     String
  messages  Json     @default("[]")
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([orgId])
}

model ChurnSignal {
  id         String   @id @default(cuid())
  contactId  String
  riskScore  Float
  factors    Json     @default("[]")
  detectedAt DateTime @default(now())

  @@index([contactId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}
