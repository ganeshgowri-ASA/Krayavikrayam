generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth Models ────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ────────────────────────────────────────────────────────────

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  campaigns     Campaign[]
  leadScore     LeadScore?   @relation("LeadScores")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Organization {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  logo           String?
  memberships    Membership[]
  campaigns      Campaign[]
  socialAccounts SocialAccount[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model Membership {
  id             String       @id @default(cuid())
  role           MemberRole   @default(MEMBER)
  userId         String
  organizationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

// ─── Marketing Models ──────────────────────────────────────────────────────

enum CampaignType {
  EMAIL
  SMS
  SOCIAL
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

model Campaign {
  id             String         @id @default(cuid())
  name           String
  type           CampaignType
  status         CampaignStatus @default(DRAFT)
  organizationId String
  createdBy      String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        User           @relation(fields: [createdBy], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId])
  @@index([createdBy])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  htmlBody  String   @db.Text
  jsonBody  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadScore {
  id        String   @id @default(cuid())
  contactId String
  score     Int      @default(0)
  factors   Json
  contact   User     @relation("LeadScores", fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId])
  @@index([score])
}

model DripSequence {
  id        String   @id @default(cuid())
  name      String
  steps     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  WHATSAPP
  YOUTUBE
  X_TWITTER
  TELEGRAM
  REFERRAL
}

model SocialAccount {
  id             String         @id @default(cuid())
  platform       SocialPlatform
  accountName    String
  accountId      String
  accessToken    String?        @db.Text
  organizationId String
  followersCount Int            @default(0)
  isConnected    Boolean        @default(false)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  posts          SocialPost[]
  metrics        ChannelMetric[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId])
  @@index([platform])
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

model SocialPost {
  id              String        @id @default(cuid())
  content         String        @db.Text
  platform        SocialPlatform
  scheduledAt     DateTime?
  publishedAt     DateTime?
  status          PostStatus    @default(DRAFT)
  socialAccountId String
  engagement      Json?
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([socialAccountId])
  @@index([status])
  @@index([scheduledAt])
}

model ChannelMetric {
  id              String        @id @default(cuid())
  socialAccountId String
  date            DateTime
  followers       Int           @default(0)
  impressions     Int           @default(0)
  engagementRate  Float         @default(0)
  clicks          Int           @default(0)
  conversions     Int           @default(0)
  revenue         Float         @default(0)
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@index([socialAccountId])
  @@index([date])
  @@unique([socialAccountId, date])
}
