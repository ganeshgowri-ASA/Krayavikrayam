{
  "schema_version": "1.0",
  "standard": "IEC 61215-2:2021 Module Qualification Tests (MQT)",
  "ref_pdf": "08-engineering/iec-61215-2-2021/IEC-61215-2-2021.pdf (place here, kept out of git)",
  "module_geometry": {
    "comment": "Default DUT geometry used to size every chamber unless RFQ overrides.",
    "length_mm": 2000,
    "width_mm": 1050,
    "thickness_mm": 35,
    "weight_kg": 27,
    "wafer_class_default": "M10"
  },
  "mqt": {
    "MQT_01": {
      "name": "Visual inspection",
      "spec": { "illumination_lux_min": 1000, "illumination_type": "diffuse" },
      "equipment": "08_Visual_Inspection"
    },
    "MQT_02": {
      "name": "Maximum power determination",
      "equipment": "06_SteadyState_SunSimulator",
      "depends_on": ["IEC 60904-9:2020"]
    },
    "MQT_03": {
      "name": "Insulation test",
      "spec": { "min_insulation_resistance_MOhm_per_m2": 40 },
      "equipment": "09_Combined_Hipot_CS_RCOT_IVG"
    },
    "MQT_06": {
      "name": "Performance at STC",
      "spec": { "irradiance_W_per_m2": 1000, "module_temp_C": 25, "AM": 1.5 },
      "equipment": "06_SteadyState_SunSimulator"
    },
    "MQT_09": {
      "name": "NMOT / NOCT determination",
      "equipment": "06_SteadyState_SunSimulator"
    },
    "MQT_10": {
