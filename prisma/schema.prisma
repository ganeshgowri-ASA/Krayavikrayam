// ─── Enums ──────────────────────────────────────────────────────────────────

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  MEMBER
  VIEWER
}

enum ContactStatus {
  LEAD
  PROSPECT
  CUSTOMER
  CHURNED
  INACTIVE
}

enum ContactSource {
  WEBSITE
  REFERRAL
  LINKEDIN
  COLD_CALL
  TRADE_SHOW
  ADVERTISEMENT
  OTHER
}

enum ActivityType {
  CALL
  EMAIL
  MEETING
  NOTE
  STAGE_CHANGE
  STATUS_CHANGE
  TASK
  OTHER
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum CampaignType {
  EMAIL
  SMS
  SOCIAL
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
}

enum SocialPlatform {
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  WHATSAPP
  YOUTUBE
  X_TWITTER
  TELEGRAM
  REFERRAL
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  FAILED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

// ─── Auth / Org Models ───────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id             String       @id @default(cuid())
  name           String?
  email          String?      @unique
  emailVerified  DateTime?
  image          String?
  password       String?
  role           MemberRole   @default(MEMBER)
  orgId          String?
  accounts       Account[]
  sessions       Session[]
  memberships    Membership[]
  contacts       Contact[]    @relation("CreatedByUser")
  activities     Activity[]
  campaigns      Campaign[]
  leadScores     LeadScore[]  @relation("UserLeadScores")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization? @relation("OrgUsers", fields: [orgId], references: [id])
}

model Organization {
  id             String          @id @default(cuid())
  name           String
  slug           String          @unique
  logo           String?
  memberships    Membership[]
  users          User[]          @relation("OrgUsers")
  contacts       Contact[]
  companies      Company[]
  campaigns      Campaign[]
  socialAccounts SocialAccount[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Membership {
  id             String       @id @default(cuid())
  role           MemberRole   @default(MEMBER)
  userId         String
  organizationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([userId, organizationId])
  @@index([userId])
  @@index([organizationId])
}

// ─── CRM Models ──────────────────────────────────────────────────────────────

model Contact {
  id           String        @id @default(cuid())
  name         String
  email        String?
  phone        String?
  company      String?
  source       ContactSource @default(OTHER)
  status       ContactStatus @default(LEAD)
  customFields Json?
  orgId        String
  createdById  String
  companyId    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  organization Organization  @relation(fields: [orgId], references: [id])
  createdBy    User          @relation("CreatedByUser", fields: [createdById], references: [id])
  companyRef   Company?      @relation(fields: [companyId], references: [id])
  activities   Activity[]
  contactTags  ContactTag[]

  @@index([orgId])
  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([source])
}

model Company {
  id          String   @id @default(cuid())
  name        String
  industry    String?
  website     String?
  size        String?
  revenue     String?
  address     String?
  orgId       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id])
  contacts     Contact[]

  @@index([orgId])
}

model Activity {
  id          String       @id @default(cuid())
  type        ActivityType
  subject     String
  description String?      @db.Text
  contactId   String?
  dealId      String?
  userId      String
  scheduledAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  contact Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])

  @@index([contactId])
  @@index([userId])
}

model Tag {
  id        String       @id @default(cuid())
  name      String       @unique
  color     String       @default("#6B7280")
  createdAt DateTime     @default(now())

  contactTags ContactTag[]
}

model ContactTag {
  contactId String
  tagId     String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
}

// ─── Sales Pipeline Models ───────────────────────────────────────────────────

model Pipeline {
  id        String   @id @default(cuid())
  name      String
  orgId     String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stages PipelineStage[]

  @@index([orgId])
}

model PipelineStage {
  id          String   @id @default(cuid())
  name        String
  order       Int
  probability Float    @default(0)
  pipelineId  String
  color       String   @default("#3b82f6")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pipeline Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals    Deal[]

  @@index([pipelineId])
}

model Deal {
  id                String     @id @default(cuid())
  title             String
  value             Float      @default(0)
  currency          String     @default("USD")
  expectedCloseDate DateTime?
  stageId           String
  contactId         String?
  contactName       String?
  accountId         String?
  accountName       String?
  ownerId           String?
  ownerName         String?
  orgId             String
  probability       Float      @default(0)
  status            DealStatus @default(OPEN)
  notes             String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  stage          PipelineStage  @relation(fields: [stageId], references: [id])
  dealActivities DealActivity[]
  quotes         Quote[]

  @@index([stageId])
  @@index([orgId])
  @@index([status])
}

model DealActivity {
  id        String       @id @default(cuid())
  dealId    String
  type      ActivityType
  title     String
  notes     String?
  userId    String?
  userName  String?
  metadata  Json?
  createdAt DateTime     @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
}

model Quota {
  id             String   @id @default(cuid())
  userId         String
  userName       String?
  period         String
  targetAmount   Float
  achievedAmount Float    @default(0)
  orgId          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, period])
  @@index([orgId])
}

// ─── Marketing Hub Models ─────────────────────────────────────────────────────

model Campaign {
  id             String         @id @default(cuid())
  name           String
  type           CampaignType
  status         CampaignStatus @default(DRAFT)
  organizationId String
  createdBy      String
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator        User           @relation(fields: [createdBy], references: [id])
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([organizationId])
  @@index([createdBy])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  htmlBody  String   @db.Text
  jsonBody  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LeadScore {
  id        String   @id @default(cuid())
  contactId String
  score     Int      @default(0)
  factors   Json
  contact   User     @relation("UserLeadScores", fields: [contactId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([contactId])
  @@index([score])
}

model DripSequence {
  id        String   @id @default(cuid())
  name      String
  steps     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialAccount {
  id             String          @id @default(cuid())
  platform       SocialPlatform
  accountName    String
  accountId      String
  accessToken    String?         @db.Text
  organizationId String
  followersCount Int             @default(0)
  isConnected    Boolean         @default(false)
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  posts          SocialPost[]
  metrics        ChannelMetric[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([organizationId])
  @@index([platform])
}

model SocialPost {
  id              String         @id @default(cuid())
  content         String         @db.Text
  platform        SocialPlatform
  scheduledAt     DateTime?
  publishedAt     DateTime?
  status          PostStatus     @default(DRAFT)
  socialAccountId String
  engagement      Json?
  socialAccount   SocialAccount  @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([socialAccountId])
  @@index([status])
  @@index([scheduledAt])
}

model ChannelMetric {
  id              String        @id @default(cuid())
  socialAccountId String
  date            DateTime
  followers       Int           @default(0)
  impressions     Int           @default(0)
  engagementRate  Float         @default(0)
  clicks          Int           @default(0)
  conversions     Int           @default(0)
  revenue         Float         @default(0)
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)

  @@unique([socialAccountId, date])
  @@index([socialAccountId])
  @@index([date])
}

// ─── Service Tickets ──────────────────────────────────────────────────────────

model Ticket {
  id          String         @id @default(cuid())
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  contactId   String?
  assignedTo  String?
  orgId       String
  slaDeadline DateTime?
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  comments   TicketComment[]
  csatSurvey CsatSurvey?

  @@index([orgId])
  @@index([status])
  @@index([priority])
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  userId     String
  content    String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}

model SlaRule {
  id                  String         @id @default(cuid())
  name                String
  priority            TicketPriority
  responseTimeHours   Int
  resolutionTimeHours Int
  orgId               String
  createdAt           DateTime       @default(now())

  @@index([orgId])
}

model KnowledgeBase {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  category    String
  orgId       String
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orgId])
  @@index([category])
}

model CsatSurvey {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  rating    Int?
  feedback  String?
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

// ─── ERP-Light ────────────────────────────────────────────────────────────────

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String   @unique
  price       Float
  currency    String   @default("USD")
  orgId       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  invoiceItems InvoiceItem[]
  quoteItems   QuoteItem[]

  @@index([orgId])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  contactId     String?
  accountId     String?
  status        InvoiceStatus @default(DRAFT)
  dueDate       DateTime?
  totalAmount   Float         @default(0)
  orgId         String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  items    InvoiceItem[]
  payments Payment[]

  @@index([orgId])
  @@index([status])
}

model InvoiceItem {
  id        String @id @default(cuid())
  invoiceId String
  productId String
  quantity  Int    @default(1)
  unitPrice Float
  total     Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([invoiceId])
}

model Payment {
  id          String   @id @default(cuid())
  invoiceId   String
  amount      Float
  paymentDate DateTime
  method      String
  reference   String?
  createdAt   DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

// ─── CPQ (Configure-Price-Quote) ─────────────────────────────────────────────

