# LLM provider — set to "openai" to use a real model, "fake" for deterministic local dev/tests.
PROCUREMENT_LLM_PROVIDER=fake
PROCUREMENT_LLM_MODEL=gpt-4o-mini
PROCUREMENT_LLM_TEMPERATURE=0.0

# OpenAI (only required if PROCUREMENT_LLM_PROVIDER=openai)
OPENAI_API_KEY=

# Server
PROCUREMENT_HOST=0.0.0.0
PROCUREMENT_PORT=8088

# Guardrails
PROCUREMENT_PII_REDACTION=true
PROCUREMENT_HALLUCINATION_GUARD=true

# Logging
LOG_LEVEL=INFO
